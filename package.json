{
  "name": "opencode-openauto",
  "version": "0.1.0",
  "description": "OpenAuto — standalone CLI + opencode plugin for automatic LLM routing. Premium-first with consent-based free fallback.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "openauto": "./dist/cli/main.js",
    "opencode-openauto": "./dist/cli/main.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "scripts",
    "README.md",
    "CONTRIBUTING.md",
    "LICENSE"
  ],
  "scripts": {
    "compile": "tsc",
    "watch": "tsc -w",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "prepublishOnly": "tsc && vitest run"
  },
  "devDependencies": {
    "@ai-sdk/openai-compatible": ">=1.0.0",
    "@opencode-ai/plugin": "1.4.3",
    "@opencode-ai/sdk": "1.4.3",
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^2.1.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  },
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "opencode",
    "opencode-plugin",
    "llm",
    "router",
    "model-routing",
    "ai",
    "anthropic",
    "openai",
    "openrouter"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/yagneshempyreal-dotcom/opencode-autopilot.git"
  }
}
